{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "betteraudio",
	"version": "0.1.0",
	"identifier": "com.heorhii.betteraudio",
	"build": {
		"beforeDevCommand": "bun run dev",
		"devUrl": "http://localhost:1420",
		"beforeBuildCommand": "bun run build",
		"frontendDist": "../build"
	},
	"app": {
		"windows": [
			{
				"title": "BetterAudio",
				"width": 1200,
				"height": 800,
				"dragDropEnabled": false
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		],
		"macOS": {
			"infoPlist": "Info.plist"
		}
	}
}
